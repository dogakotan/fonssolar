# Bu dosyayi ayni klasorde ".env.local" olarak kopyalayip SUPABASE_DB_URL'i doldurun.
# Supabase Dashboard > Project Settings > Database > Connection string (URI) - "Direct connection" onerilir.
# Ornek format: postgresql://postgres:[SIFRENIZ]@db.bshhgvdzemgfijkzhcrf.supabase.co:5432/postgres
#
# ONEMLI: .env.local dosyasi git'e GIRMEZ (.gitignore'da tanimli). Sifreyi
# hicbir zaman commit mesajina, chat'e ya da baska bir dosyaya yazmayin.
SUPABASE_DB_URL=
